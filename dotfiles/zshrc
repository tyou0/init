# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# If you come from bash you might have to change your $PATH.
# export PATH=$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH
export BUN_INSTALL="$HOME/.bun"
case "$(uname -s)" in
  Darwin)
    export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:$BUN_INSTALL/bin:$PATH"
    ;;
  *)
    export PATH="$HOME/.local/bin:$BUN_INSTALL/bin:$PATH"
    ;;
esac

# Fix for cmux/Ghostty SSH connections - fall back to xterm-256color
[[ $TERM == "xterm-ghostty" ]] && export TERM=xterm-256color

# Use Bitwarden desktop as the SSH agent so git/ssh auth follows the same
# desktop login state across terminals.
export SSH_AUTH_SOCK="$HOME/.bitwarden-ssh-agent.sock"

# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Set name of the theme to load --- if set to "random", it will
# load a random theme each time Oh My Zsh is loaded, in which case,
# to know which specific one was loaded, run: echo $RANDOM_THEME
# See https://github.com/ohmyzsh/ohmyzsh/wiki/Themes
ZSH_THEME="powerlevel10k/powerlevel10k"

# Which plugins would you like to load?
# Standard plugins can be found in $ZSH/plugins/
# Custom plugins may be added to $ZSH_CUSTOM/plugins/
# Example format: plugins=(rails git textmate ruby lighthouse)
# Add wisely, as too many plugins slow down shell startup.
plugins=(git)

if [ -r "$ZSH/oh-my-zsh.sh" ]; then
  source "$ZSH/oh-my-zsh.sh"
fi

# User configuration

# Preferred editor for local and remote sessions
# if [[ -n $SSH_CONNECTION ]]; then
#   export EDITOR='vim'
# else
#   export EDITOR='nvim'
# fi

alias born='f(){ command -v bun >/dev/null 2>&1 && bun "$@" || node "$@"; }; f'
if command -v fdfind >/dev/null 2>&1; then
  alias fd='fdfind'
fi
alias gitclean='git branch --merged origin/main | grep -vE "^\s*(\*|main|develop)" | xargs -n 1 git branch -d'
alias ccyolo='claude --permission-mode bypassPermissions'
alias cch='claude -p --permission-mode bypassPermissions'

# BEGIN init aliases
[ -f "$HOME/.aliases" ] && . "$HOME/.aliases"
# END init aliases

# BEGIN init mise and direnv
command -v mise >/dev/null 2>&1 && eval "$(mise activate zsh --quiet)"
command -v direnv >/dev/null 2>&1 && eval "$(direnv hook zsh)"
# END init mise and direnv

# BEGIN init zim
export ZIM_HOME="${ZDOTDIR:-$HOME}/.zim"
[ -f "$ZIM_HOME/init.zsh" ] && source "$ZIM_HOME/init.zsh"
[ -f "$ZIM_HOME/zimfw.zsh" ] && zimfw() { source "$ZIM_HOME/zimfw.zsh" "$@"; }
# END init zim

# Restore fish-like history navigation after Zim loads the widget definitions.
if (( ${+widgets[history-substring-search-up]} && ${+widgets[history-substring-search-down]} )); then
  bindkey '^[[A' history-substring-search-up
  bindkey '^[[B' history-substring-search-down
  [[ -n ${terminfo[kcuu1]-} ]] && bindkey "${terminfo[kcuu1]}" history-substring-search-up
  [[ -n ${terminfo[kcud1]-} ]] && bindkey "${terminfo[kcud1]}" history-substring-search-down
fi

# Ensure the prompt theme from the installed Zim module is active in the shell.
[ -f "$ZIM_HOME/modules/powerlevel10k/powerlevel10k.zsh-theme" ] && source "$ZIM_HOME/modules/powerlevel10k/powerlevel10k.zsh-theme"

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# pnpm
export PNPM_HOME="$HOME/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
# Most JS repos here use pnpm or bun. Keeping `npm` mapped to pnpm avoids
# accidentally creating a second lockfile or mixed install state.
alias npm='pnpm'
# pnpm end
command -v tv >/dev/null 2>&1 && eval "$(tv init zsh)"

# BEGIN init p10k configure
if [ ! -f "$HOME/.p10k.zsh" ] && command -v p10k >/dev/null 2>&1; then
  (sleep 1; p10k configure) &
fi
# END init p10k configure
